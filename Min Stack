class MinStack:

    def __init__(self):
        self.a = []
        self.t = -1
        

    def push(self, val: int) -> None:
        self.a.append(val)
        self.t+=1
       
        

    def pop(self) -> None:
        self.t-=1
        self.a.pop()
     
        

    def top(self) -> int:
        return  self.a[self.t]
        

    def getMin(self) -> int:
        return min(self.a)
        



class Solution:
    def simplifyPath(self, path: str) -> str:
        a = path.split("/")
        b=[]
        for i in a:
            if i == "" or i == ".":
                continue
            if i == "..":
                if b:
                    b.pop()
            else:
                b.append(i) 
        return "/" + "/".join(b)   

class Solution:
    def uncommonFromSentences(self, s1: str, s2: str) -> List[str]:
        words = (s1 + " " + s2).split()
        count = {}
        
        for w in words:
            count[w] = count.get(w, 0) + 1
        
        result = []
        for w in count:
            if count[w] == 1:
                result.append(w)
        
        return result
